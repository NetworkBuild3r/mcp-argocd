# Copy to .env and fill in. Never commit .env.

# Argo CD API base URL (no trailing slash), e.g. https://argocd.example.com
ARGOCD_BASE_URL=https://argocd.example.com

# Argo CD API token (Settings → Accounts → generate token, or CLI)
# https://argo-cd.readthedocs.io/en/stable/developer-guide/api-docs/#authorization
ARGOCD_API_TOKEN=

# Optional: only if Argo CD uses a self-signed or private CA cert (dev only)
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Optional: disable mutating tools (create/update/delete/sync/actions)
# MCP_READ_ONLY=true
